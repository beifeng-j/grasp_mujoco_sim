<mujoco model="scene">

    <compiler angle="radian" autolimits="true" />
    <option timestep="0.002" integrator="implicitfast" solver="PGS" gravity="0 0 -9.82" viscosity="0.1"
            cone="elliptic">
		<!--		 <flag multiccd="enable"/>-->
    </option>

    <include file="../piper/piper.xml" />


    <statistic center="0.3 0 0.3" extent="0.8" meansize="0.08" />

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0" />
        <rgba haze="0.15 0.25 0.35 1" />
        <global azimuth="120" elevation="-20" />
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512"
                 height="3072" />
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
                 rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
                  reflectance="0.2" />

        <!--meshes-->
        <mesh name ="table" file="../table/sigmund_table.stl" scale= "1 1 1"/>
        <mesh name="banana_mesh" file="../objects/Banana.STL" scale="0.001 0.001 0.001"
              refpos="104.48488596081734 20.805833607912064 28.255835086107254"/>
        <mesh name="strawberry_mesh" file="../objects/nontextured.stl" scale="1 1 1"
              refpos="-0.00744779035449028 0.003532206639647484 0.02275029430165887"/>
        <mesh name="large_box_mesh" file="../objects/large-box.obj" scale="0.002625 0.002625 0.001"
              refpos="716.542 -543.897 2.223"/>
    </asset>

    <worldbody>
        <light pos="0 0 1.5" dir="0 0 -1" directional="true" />
		<geom name="floor" size="0 0 0.05" type="plane" material="groundplane" />
		<geom name="x-aixs" group="2" type="cylinder" contype="0" conaffinity="0"
			fromto="0 0 0 1 0 0" size="0.01" rgba="1 0 0 1" />
		<geom name="y-aixs" group="2" type="cylinder" contype="0" conaffinity="0"
			fromto="0 0 0 0 1 0" size="0.01" rgba="0 1 0 1" />
		<geom name="z-aixs" group="2" type="cylinder" contype="0" conaffinity="0"
			fromto="0 0 0 0 0 1" size="0.01" rgba="0 0 1 1" />

		<camera name="cam" pos="1.0 0.6 2.0" xyaxes="0 1 0 -1 0 -0.5" mode="fixed" />

		<body name="mocap" mocap="true" pos="0.8 0.6 0.74">
			<geom name="mocap" type="sphere" size="0.000001"/>
		</body>

		<body name="Box" pos="1.2 0.7 0.9" quat="1 0 0 0">
			<joint name="Box" type="free" damping="0.05"/>
			<geom name="Box" type="box" size="0.015 0.015 0.015" rgba="1 0 1 1" condim="6"
			      friction="0.8 0.05 0.01" solref="0.004 1" solimp="0.95 0.99 0.001"/>
		</body>

		<body name="Banana" pos="1.2 0.5 0.85" quat="1 0 0 0">
			<joint name="Banana" type="free" damping="0.05"/>
			<geom name="Banana_visual" type="mesh" mesh="banana_mesh" rgba="0.95 0.85 0.2 1"
			      contype="0" conaffinity="0" density="0"/>
			<geom name="Banana" type="capsule" fromto="-0.085 0 0 0.085 0 0" size="0.018"
			      mass="0.15" condim="6" friction="0.8 0.05 0.01" solref="0.004 1"
			      solimp="0.95 0.99 0.001"/>
		</body>

		<body name="Strawberry" pos="1.2 0.6 0.85" quat="1 0 0 0">
			<joint name="Strawberry" type="free" damping="0.05"/>
			<geom name="Strawberry_visual" type="mesh" mesh="strawberry_mesh" rgba="0.9 0.15 0.25 1"
			      contype="0" conaffinity="0" density="0"/>
			<geom name="Strawberry" type="sphere" size="0.022"
			      mass="0.05" condim="6" friction="0.8 0.05 0.01" solref="0.004 1"
			      solimp="0.95 0.99 0.001"/>
		</body>

		<body name="Cylinder" pos="1.4 0.6 0.9" euler="1.5708 0 0">
			<joint name="Cylinder" type="free" damping="0.2"/>
			<geom name="Cylinder" type="cylinder" size="0.025 0.1" rgba="1 1 0 1" condim="6"
			      friction="0.9 0.05 0.01" solref="0.004 1" solimp="0.95 0.99 0.001"/>
		</body>

		<body name="large_box" pos="0.4 0.2 0.758" quat="1 0 0 0">
			<joint name="large_box" type="free" damping="0.08"/>
			<geom name="large_box_visual" type="mesh" mesh="large_box_mesh" rgba="0.75 0.75 0.75 1"
			      contype="0" conaffinity="0" density="0"/>
			<!-- Bottom plate -->
			<geom name="large_box" type="box" pos="0 0 -0.0165" size="0.20 0.20 0.0015"
			      mass="0.3" condim="6" friction="0.8 0.05 0.01" solref="0.004 1"
			      solimp="0.95 0.99 0.001"/>
			<!-- Front wall (+Y) -->
			<geom name="large_box_wall_0" type="box" pos="0 0.198 0" size="0.20 0.002 0.017"
			      mass="0.05" condim="6" friction="0.8 0.05 0.01" solref="0.004 1"
			      solimp="0.95 0.99 0.001"/>
			<!-- Back wall (-Y) -->
			<geom name="large_box_wall_1" type="box" pos="0 -0.198 0" size="0.20 0.002 0.017"
			      mass="0.05" condim="6" friction="0.8 0.05 0.01" solref="0.004 1"
			      solimp="0.95 0.99 0.001"/>
			<!-- Left wall (-X) -->
			<geom name="large_box_wall_2" type="box" pos="-0.198 0 0" size="0.002 0.20 0.017"
			      mass="0.05" condim="6" friction="0.8 0.05 0.01" solref="0.004 1"
			      solimp="0.95 0.99 0.001"/>
			<!-- Right wall (+X) -->
			<geom name="large_box_wall_3" type="box" pos="0.198 0 0" size="0.002 0.20 0.017"
			      mass="0.05" condim="6" friction="0.8 0.05 0.01" solref="0.004 1"
			      solimp="0.95 0.99 0.001"/>
		</body>

		<!--Zones-->
		<body name="zone_pickup" pos="1.2 0.6 0.73" quat="1 0 0 0">
			<geom name="zone_pickup" type="box" size="0.2 0.6 0.01" rgba="0 1 0 0.1" contype="0" conaffinity="0"/>
		</body>
		<body name="zone_drop" pos="0.4 0.2 0.73" quat="1 0 0 0">
			<geom name="zone_drop" type="box" size="0.2 0.2 0.01" rgba="1 0 0 0.1" contype="0" conaffinity="0"/>
		</body>

        <!--table -->
		<body name = "table1" euler="0 0 0" pos= "0.8 0 0.74" >
		  <geom name = "table1" type="mesh" mesh="table" group="2" rgba="0.35 0.35 0.35 1" mass="0" contype="0" conaffinity="0"/>
		</body>
		<body name = "table2" euler="0 0 0" pos= "1.6 0 0.74" >
		  <geom name = "table2" type="mesh" mesh="table" group="2" rgba="0.35 0.35 0.35 1" mass="0" contype="0" conaffinity="0"/>
		</body>

		<body name="simple_table" pos="0.8 0.6 0.69" quat="1 0 0 0">
			<geom name="simple_table" type="box" size="0.8 0.6 0.05" rgba="0.5 0.5 0.5 0.1"/>
		</body>
    </worldbody>

</mujoco>
